OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/local/research-paper-reviewer-agent
OPENROUTER_TITLE=Research Paper Reviewer Agent

WORKER_MODEL=anthropic/claude-sonnet-4.5
EVALUATOR_MODEL=anthropic/claude-opus-4.1
PLANNER_MODEL=anthropic/claude-sonnet-4.5

PAPER_COUNT=5
ARXIV_QUERY=

# Auto-approve T6 (final report) for unattended runs. Unset by default.
# AUTO_APPROVE=1

# Per-task-type attempt caps. Format: task_type=N,task_type=N,...
# Defaults: summarize_paper=5, export_pdf=2, all-other=MAX_ATTEMPTS_PER_TASK (3).
# MAX_ATTEMPTS_PER_TASK=3
# MAX_ATTEMPTS_BY_TYPE=summarize_paper=5,export_pdf=2
